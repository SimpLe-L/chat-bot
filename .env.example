# Frontend
VITE_API_BASE_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3003,http://127.0.0.1:3003,http://localhost:3004,http://127.0.0.1:3004

# Local infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nebulai
POSTGRES_USER=nebulai
POSTGRES_PASSWORD=nebulai
REDIS_URL=redis://localhost:6379/0
MILVUS_URI=http://localhost:19530

# OpenAI-compatible providers
# Fill OPENAI_API_KEY once if the same key should be used for both LLM and embeddings.
# For separate providers, prefer LLM_API_KEY and EMBEDDING_API_KEY below.
OPENAI_API_KEY=
# Optional shared SiliconFlow key for LLM, embedding, and rerank.
SILICONFLOW_API_KEY=

# Chat completions provider
# Mock mode is enough for local tests. Use openai-compatible for OpenAI, SiliconFlow, or compatible APIs.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
# SiliconFlow example:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
# LLM_API_KEY=

# Embedding provider
# Keep mock-hash unless you intentionally want real embeddings and have checked the model dimension.
EMBEDDING_PROVIDER=mock-hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=384
EMBEDDING_SEND_DIMENSIONS=true
EMBEDDING_TIMEOUT_SECONDS=15
# SiliconFlow BAAI/bge-m3 embedding example. It returns 1024 dimensions and should not receive a dimensions field.
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_API_KEY=
# EMBEDDING_DIMENSION=1024
# EMBEDDING_SEND_DIMENSIONS=false

# Optional rerank provider. Prefer RERANK_* for new config; JINA_* remains supported for compatibility.
RERANK_PROVIDER=jina
RERANK_API_KEY=
RERANK_URL=
RERANK_MODEL=
RERANK_TIMEOUT_SECONDS=15
RERANK_INSTRUCTION=
# RERANK_MAX_CHUNKS_PER_DOC=8
# RERANK_OVERLAP_TOKENS=64
JINA_API_KEY=
JINA_RERANK_URL=https://api.jina.ai/v1/rerank
JINA_RERANK_MODEL=
JINA_RERANK_TIMEOUT_SECONDS=15
# SiliconFlow rerank example:
# RERANK_PROVIDER=siliconflow
# RERANK_URL=https://api.siliconflow.cn/v1/rerank
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_API_KEY=
# RERANK_INSTRUCTION=Given a private knowledge base query, rank passages by relevance.
